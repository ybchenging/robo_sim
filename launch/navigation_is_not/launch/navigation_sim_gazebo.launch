<?xml version="1.0"?>
<launch>
    <!-- ==================== 全局仿真时间设置 ==================== -->
    <!-- 关键：必须在所有节点之前设置，确保所有节点都能获取到 -->
    <param name="/use_sim_time" value="true"/>

    <arg name="map_file" default="$(find robo_sim)/maps/my_map1.yaml"/>
    <arg name="local_planner" default="teb"/>
    <arg name="open_rviz" default="true"/>

    <!-- ==================== 地图服务器 ==================== -->
    <node pkg="map_server" type="map_server" name="map_server" output="screen" 
          args="$(arg map_file)">
        <param name="frame_id" value="map"/>
        <!-- 明确启用仿真时间 -->
        <param name="use_sim_time" value="true"/>
    </node>

    <!-- ==================== AMCL（优化版）==================== -->
    <node pkg="amcl" type="amcl" name="amcl" output="screen">
        <!-- 明确启用仿真时间 -->
        <param name="use_sim_time" value="true"/>
        
        <remap from="scan" to="/scan"/>
        
        <param name="odom_frame_id" value="odom"/>
        <param name="base_frame_id" value="base_footprint"/>
        <param name="global_frame_id" value="map"/>
        
        <!-- 初始位姿 -->
        <param name="initial_pose_x" value="0.0"/>
        <param name="initial_pose_y" value="0.0"/>
        <param name="initial_pose_a" value="0.0"/>
        
        <!-- 减少计算延迟 -->
        <param name="min_particles" value="100"/>
        <param name="max_particles" value="1000"/>
        <param name="laser_max_beams" value="60"/>
        <param name="update_min_d" value="0.2"/>
        <param name="update_min_a" value="0.5"/>
        
        <!-- 关键：变换容忍度（仿真时间下建议适当增大） -->
        <param name="transform_tolerance" value="0.5"/>
    </node>

    <!-- ==================== Move Base（关键修复）==================== -->
    <node pkg="move_base" type="move_base" name="move_base" output="screen">
        <!-- 明确启用仿真时间 -->
        <param name="use_sim_time" value="true"/>
        
        <param name="base_local_planner" 
               value="$(eval 'teb_local_planner/TebLocalPlannerROS' if arg('local_planner') == 'teb' else 'dwa_local_planner/DWAPlannerROS')"/>
        <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
        
        <!-- 坐标系 -->
        <param name="global_costmap/global_frame" value="map"/>
        <param name="global_costmap/robot_base_frame" value="base_footprint"/>
        <param name="local_costmap/global_frame" value="odom"/>
        <param name="local_costmap/robot_base_frame" value="base_footprint"/>
        
        <!-- ==================== 关键修复：变换容忍度 ==================== -->
        <!-- 仿真时间下建议增大到0.5-1.0，防止TF超时 -->
        <param name="global_costmap/transform_tolerance" value="0.5"/>
        <param name="local_costmap/transform_tolerance" value="0.5"/>
        
        <!-- 频率（仿真时间下可适当降低，减轻计算负担） -->
        <param name="controller_frequency" value="20.0"/>
        <param name="planner_frequency" value="1.0"/>
        
        <!-- 其他参数... -->
        <rosparam file="$(find robo_sim)/navigation/config/costmap_common_params.yaml" command="load" ns="global_costmap"/>
        <rosparam file="$(find robo_sim)/navigation/config/costmap_common_params.yaml" command="load" ns="local_costmap"/>
        <rosparam file="$(find robo_sim)/navigation/config/global_costmap_params.yaml" command="load"/>
        <rosparam file="$(find robo_sim)/navigation/config/local_costmap_params.yaml" command="load"/>
        <rosparam file="$(find robo_sim)/navigation/config/global_planner_params.yaml" command="load"/>
        <rosparam file="$(find robo_sim)/navigation/config/$(arg local_planner)_local_planner_params.yaml" command="load"/>
    </node>

    <!-- RViz -->
    <group if="$(arg open_rviz)">
        <node pkg="rviz" type="rviz" name="rviz" 
              args="-d $(find robo_sim)/navigation/config/navigation.rviz">
            <!-- 明确启用仿真时间 -->
            <param name="use_sim_time" value="true"/>
        </node>
    </group>

</launch>