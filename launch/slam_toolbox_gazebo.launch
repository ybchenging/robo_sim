<?xml version="1.0"?>
<launch>
    <!-- ==================== 参数配置 ==================== -->
    <!-- 坐标系设置 -->
    <arg name="odom_frame" default="odom"/>
    <arg name="map_frame" default="map"/>
    <arg name="base_frame" default="base_footprint"/>
    
    <!-- 话题设置 -->
    <arg name="scan_topic" default="/scan"/>
    
    <!-- 运行模式：mapping（建图）或 localization（定位） -->
    <arg name="mode" default="mapping"/>
    
    <!-- 地图保存路径（建图模式使用） -->
    <arg name="map_file" default="$(find robo_sim)/maps/my_map"/>

    <!-- ==================== 建图模式 ==================== -->
    <group if="$(eval arg('mode') == 'mapping')">
        <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
            <!-- 话题重映射 -->
            <remap from="scan" to="$(arg scan_topic)"/>
            
            <!-- 坐标系 -->
            <param name="odom_frame" value="$(arg odom_frame)"/>
            <param name="base_frame" value="$(arg base_frame)"/>
            <param name="map_frame" value="$(arg map_frame)"/>
            
            <!-- 激光参数 -->
            <param name="maxUrange" value="8.0"/>        <!-- 最大可用范围 -->
            <param name="maxRange" value="10.0"/>       <!-- 激光最大范围 -->
            <param name="delta" value="0.05"/>          <!-- 地图分辨率 -->
            
            <!-- 更新阈值（对应 slam_toolbox 的 minimum_travel_distance） -->
            <param name="linearUpdate" value="0.1"/>    <!-- 线性移动更新阈值0.5 -->
            <param name="angularUpdate" value="0.1"/>   <!-- 角度更新阈值0.5 -->
            <param name="temporalUpdate" value="1.0"/>  <!-- 时间更新阈值2.0 -->
            
            <!-- 粒子滤波 -->
            <param name="particles" value="80"/>
            <param name="minimumScore" value="50"/>
            
            <!-- 运动模型参数 -->
            <param name="srr" value="0.01"/>   <!-- 线速度->线速度噪声 -->
            <param name="srt" value="0.02"/>   <!-- 线速度->角速度噪声 -->
            <param name="str" value="0.01"/>   <!-- 角速度->线速度噪声 -->
            <param name="stt" value="0.02"/>   <!-- 角速度->角速度噪声 -->
            
            <!-- 地图尺寸（动态扩展） -->
            <param name="xmin" value="-50.0"/>
            <param name="ymin" value="-50.0"/>
            <param name="xmax" value="50.0"/>
            <param name="ymax" value="50.0"/>
            
            <!-- 迭代优化 -->
            <param name="linearUpdate" value="0.2"/>
            <param name="angularUpdate" value="0.1"/>
            <param name="resampleThreshold" value="0.5"/>
        </node>
        
        <!-- 地图保存服务（可选，自动保存） -->
        <node pkg="map_server" type="map_saver" name="map_saver_auto" 
              args="-f $(arg map_file)" 
              launch-prefix="bash -c 'sleep 120; $0 $@' "/>  <!-- 启动后120秒自动保存地图 -->
    </group>

    <!-- ==================== 定位模式（AMCL） ==================== -->
    <group if="$(eval arg('mode') == 'localization')">
        <!-- 加载已有地图 -->
        <node pkg="map_server" type="map_server" name="map_server" 
              args="$(arg map_file).yaml"/>
        
        <!-- AMCL 定位 -->
        <node pkg="amcl" type="amcl" name="amcl" output="screen">
            <remap from="scan" to="$(arg scan_topic)"/>
            
            <param name="odom_frame_id" value="$(arg odom_frame)"/>
            <param name="base_frame_id" value="$(arg base_frame)"/>
            <param name="global_frame_id" value="$(arg map_frame)"/>
            
            <!-- 粒子滤波参数 -->
            <param name="min_particles" value="500"/>
            <param name="max_particles" value="5000"/>
            
            <!-- 激光模型 -->
            <param name="laser_min_range" value="0.1"/>
            <param name="laser_max_range" value="8.0"/>
            <param name="laser_max_beams" value="180"/>
        </node>
    </group>

    <!-- ==================== RViz 可视化 ==================== -->
    <node pkg="rviz" type="rviz" name="rviz" 
          args="-d $(find robo_sim)/rviz/slam_rviz.rviz" 
          if="true"/>

</launch>