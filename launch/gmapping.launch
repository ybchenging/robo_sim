<launch>
 <include file="$(find robo_sim)/launch/robot_sim.launch" />
 <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
  <param name="base_frame" value="base_link"/>
  <param name="odom_frame" value="odom"/>
  <param name="map_frame" value="map"/>
  <param name="delta" value="0.1"/> <!-- 就是指分辨率（ resolution ）是0.1 m -->
  <param name="particles" value="30"/> <!-- Number of particles in the filter -->
 </node>
 <node pkg = "rviz" type = "rviz" name = "rviz" args = "-d $(find robo_sim)/launch/robo_display.rviz"/>
 <node pkg ="teleop_twist_keyboard" type="teleop_twist_keyboard.py" name="teleop_twist_keyboard" output="screen"/>
 <!-- <node pkg = "map_server" type = "map_server" name = "map_server" args = "$(find robo_sim)/slam/slam_maps/map"/> -->
</launch>
