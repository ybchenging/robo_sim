<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

<!--包含惯性计算的xacro文件-->
<xacro:include filename="$(find robo_sim)/urdf/common_inertial.xacro"/>
  <!--机器人的轮子部分-->
  <xacro:macro name = "wheel_xacro" params = "wheel_name xyz">
  <link name="${wheel_name}_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079 0 0"/> <!--沿着自己几何中心的偏移和旋转量-->
      <geometry>
        <cylinder radius="0.032" length="0.04"/>  <!--圆柱体-->
      </geometry>
      <material name="black">
        <color rgba="0 0 0 0.8"/>  <!--黑色(rgb)，半透明(0.8)-->
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079 0 0"/>
      <geometry>
        <cylinder radius="0.032" length="0.04"/>
      </geometry>
    </collision>
    <!-- <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial> -->
     <!--使用xacro文件中的惯性计算宏，传入质量和半径参数-->
    <xacro:cylinder_inertia m="0.05" r="0.032" h="0.04"/> 
    
   </link>


   
   <!--连接两个链接的关节-->
    <joint name="${wheel_name}_joint" type="continuous">
      <parent link="base_link"/>  <!--父链接 以前base_link-->  
      <child link="${wheel_name}_link"/>  <!--子链接-->
    <origin xyz="${xyz}" rpy="0 0 0"/>  <!--关节位置-->
        <axis xyz="0 1 0"/>  <!--旋转轴y,绕y轴旋转-->
    </joint>


    <gazebo reference = "${wheel_name}_link">
        <mu1 value="20"/>  <!--切向摩擦系数1-->
        <mu2 value="20"/>  <!--法向摩擦系数2-->
        <kp value="1000000000"/>  <!--接触点弹性系数-->
        <kd value="1.000"/>  <!--接触点阻尼系数-->
        <material>Gazebo/Black</material>  <!--材质-->
    </gazebo>
</xacro:macro>

</robot>